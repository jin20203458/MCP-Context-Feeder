<Window
    x:Class="CodeMergerUI.FileSelectionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:CodeMergerUI"
    Title="병합할 파일 선택"
    Width="850"
    Height="650"
    WindowStartupLocation="CenterOwner"
    local:WindowTitleBarBehavior.EnableDarkTitleBar="True"
    Background="{StaticResource VSCode.Brushes.Editor.Background}"
    Foreground="{StaticResource VSCode.Brushes.Editor.Foreground}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <!--  전체 선택 및 토글 버튼 영역  -->
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Margin="0,0,0,10"
            FontWeight="Bold"
            Text="필터링된 파일 목록입니다. 에이전트와 공유할 파일만 체크해주세요:" />

        <!--  검색창 UI 영역  -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Margin="0,0,5,0"
                VerticalAlignment="Center"
                FontWeight="Bold"
                Text="🔍 검색:" />
            <TextBox
                x:Name="TxtSearch"
                Grid.Column="1"
                Height="25"
                Style="{StaticResource VSCode.Styles.TextBox}"
                VerticalContentAlignment="Center"
                TextChanged="TxtSearch_TextChanged" />
        </Grid>

        <!--  전체 선택 체크박스 및 선택 항목만 보기 토글 버튼  -->
        <Grid Grid.Row="2" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <CheckBox
                x:Name="ChkSelectAll"
                VerticalAlignment="Center"
                Click="ChkSelectAll_Click"
                Style="{StaticResource VSCode.Styles.CheckBox}"
                Content="전체 선택 (현재 보이는 목록)"
                FontWeight="Bold" />

            <!--  추가된 토글 버튼  -->
            <ToggleButton
                x:Name="TglShowSelectedOnly"
                Grid.Column="1"
                Width="130"
                Height="25"
                Click="TglShowSelectedOnly_Click"
                Style="{StaticResource VSCode.Styles.ToggleButton}"
                Content="선택한 파일만 보기" />
        </Grid>

        <ListBox
            x:Name="LstFiles"
            Grid.Row="3"
            Style="{StaticResource VSCode.Styles.ListBox}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox
                        Margin="0,3"
                        Content="{Binding FilePath}"
                        FontSize="13"
                        Style="{StaticResource VSCode.Styles.CheckBox}"
                        IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel
            Grid.Row="4"
            Margin="0,15,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                x:Name="BtnOk"
                Width="100"
                Height="35"
                Margin="0,0,10,0"
                Click="BtnOk_Click"
                Style="{StaticResource VSCode.Styles.Button.Accent}"
                Content="선택 완료"
                FontWeight="Bold" />
            <Button
                x:Name="BtnCancel"
                Width="80"
                Height="35"
                Click="BtnCancel_Click"
                Style="{StaticResource VSCode.Styles.Button.Secondary}"
                Content="취소" />
        </StackPanel>
    </Grid>
</Window>