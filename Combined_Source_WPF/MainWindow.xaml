<Window
    x:Class="CodeMergerUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="MCP Context Gate (에이전트 제어소)"
    Width="750"
    Height="600"
    Loaded="Window_Loaded"
    WindowStartupLocation="CenterScreen"
    Background="{StaticResource VSCode.Brushes.Editor.Background}"
    Foreground="{StaticResource VSCode.Brushes.Editor.Foreground}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="0,0,0,15"
            Padding="10"
            Background="{StaticResource VSCode.Brushes.Sidebar.Background}"
            BorderBrush="{StaticResource VSCode.Brushes.Sidebar.Border}"
            BorderThickness="1"
            CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Text="📁 프리셋:" />
                <ComboBox
                    x:Name="CmbPresets"
                    Width="200"
                    Margin="0,0,10,0"
                    IsEditable="True"
                    Style="{StaticResource VSCode.Styles.ComboBox}"
                    SelectionChanged="CmbPresets_SelectionChanged" />
                <Button
                    Width="120"
                    Margin="0,0,10,0"
                    Click="BtnSavePreset_Click"
                    Style="{StaticResource VSCode.Styles.Button.Secondary}"
                    Content="💾 현재 설정 저장" />
                <Button
                    Width="80"
                    Click="BtnDeletePreset_Click"
                    Style="{StaticResource VSCode.Styles.Button.Secondary}"
                    Content="🗑️ 삭제" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock
                Margin="0,0,0,5"
                FontWeight="Bold"
                Text="소스 코드가 있는 대상 폴더 (Target Directory):" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="TxtSourcePath"
                    Height="25"
                    Style="{StaticResource VSCode.Styles.TextBox}"
                    VerticalContentAlignment="Center" />
                <Button
                    Grid.Column="1"
                    Margin="5,0,0,0"
                    Click="BtnBrowseSource_Click"
                    Style="{StaticResource VSCode.Styles.Button.Secondary}"
                    Content="찾기..." />
            </Grid>
        </StackPanel>

        <!-- Row 2: 작업 목표 (Task Intent) -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock
                Margin="0,0,0,5"
                FontWeight="Bold"
                Text="에이전트에게 지시할 작업 목표 (Task Goal / Intent):" />
            <TextBox
                x:Name="TxtTaskIntent"
                Height="60"
                Style="{StaticResource VSCode.Styles.TextBox}"
                AcceptsReturn="True"
                TextWrapping="Wrap"
                VerticalScrollBarVisibility="Auto"
                Text="예: 메인 화면의 버튼 디자인을 조금 더 현대적인 스타일로 변경하고 다크모드를 지원하도록 수정해줘." />
        </StackPanel>

        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock
                    Margin="0,0,0,5"
                    FontWeight="Bold"
                    Text="포함할 확장자:" />
                <TextBox
                    x:Name="TxtExtensions"
                    Height="25"
                    Style="{StaticResource VSCode.Styles.TextBox}"
                    VerticalContentAlignment="Center"
                    Text=".cs, .xaml, .cpp, .h" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock
                    Margin="0,0,0,5"
                    FontWeight="Bold"
                    Text="제외할 폴더:" />
                <TextBox
                    x:Name="TxtExcludedFolders"
                    Height="25"
                    Style="{StaticResource VSCode.Styles.TextBox}"
                    VerticalContentAlignment="Center"
                    Text="bin, obj, .git, .vs" />
            </StackPanel>
        </Grid>

        <!-- Row 4: 서버 제어 및 파일 선택 -->
        <Grid Grid.Row="4" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <CheckBox
                    x:Name="ChkSelectiveMerge"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Content="선택한 파일만 공유"
                    FontWeight="Bold"
                    IsChecked="True"
                    Style="{StaticResource VSCode.Styles.CheckBox}" />

                <Button
                    x:Name="BtnSelectFiles"
                    Width="100"
                    Height="40"
                    Margin="0,0,15,0"
                    Click="BtnSelectFiles_Click"
                    Style="{StaticResource VSCode.Styles.Button.Secondary}"
                    Content="📂 파일 선택..."
                    FontWeight="Bold" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button
                    x:Name="BtnToggleServer"
                    Width="180"
                    Height="40"
                    Click="BtnToggleServer_Click"
                    Style="{StaticResource VSCode.Styles.Button.Accent}"
                    Content="▶️ 서버 시작"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="White" />
            </StackPanel>

            <TextBlock
                x:Name="TxtServerAddress"
                Grid.Column="2"
                Margin="15,0,0,0"
                VerticalAlignment="Center"
                FontSize="12"
                FontWeight="Bold"
                Foreground="{StaticResource VSCode.Brushes.Text.Muted}"
                Text="서버 중지됨"
                TextWrapping="Wrap" />
        </Grid>

        <TextBlock
            Grid.Row="5"
            Margin="0,0,0,5"
            FontWeight="Bold"
            Text="진행 상황 / 로그:" />
        <TextBox
            x:Name="TxtLog"
            Grid.Row="6"
            Padding="10"
            Background="{StaticResource VSCode.Brushes.Control.InputBackground}"
            BorderBrush="{StaticResource VSCode.Brushes.Sidebar.Border}"
            Foreground="{StaticResource VSCode.Brushes.Editor.Foreground}"
            BorderThickness="1"
            FontFamily="Consolas"
            IsReadOnly="True"
            TextWrapping="Wrap"
            VerticalScrollBarVisibility="Auto" />
    </Grid>
</Window>