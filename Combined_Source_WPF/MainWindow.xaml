<Window
    x:Class="CodeMergerUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AI 소스코드 병합 도구"
    Width="750"
    Height="600"
    Loaded="Window_Loaded"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="0,0,0,15"
            Padding="10"
            Background="#F0F0F0"
            CornerRadius="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Text="📁 프리셋:" />
                <ComboBox
                    x:Name="CmbPresets"
                    Width="200"
                    Margin="0,0,10,0"
                    IsEditable="True"
                    SelectionChanged="CmbPresets_SelectionChanged" />
                <Button
                    Width="120"
                    Margin="0,0,10,0"
                    Background="#E1E1E1"
                    Click="BtnSavePreset_Click"
                    Content="💾 현재 설정 저장" />
                <Button
                    Width="80"
                    Background="#FFDCDC"
                    Click="BtnDeletePreset_Click"
                    Content="🗑️ 삭제" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock
                Margin="0,0,0,5"
                FontWeight="Bold"
                Text="소스 코드가 있는 대상 폴더 (Target Directory):" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="TxtSourcePath"
                    Height="25"
                    Padding="5,0"
                    VerticalContentAlignment="Center" />
                <Button
                    Grid.Column="1"
                    Margin="5,0,0,0"
                    Click="BtnBrowseSource_Click"
                    Content="찾기..." />
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock
                Margin="0,0,0,5"
                FontWeight="Bold"
                Text="결과물을 저장할 폴더 (Output Directory):" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="TxtOutputPath"
                    Height="25"
                    Padding="5,0"
                    VerticalContentAlignment="Center" />
                <Button
                    Grid.Column="1"
                    Margin="5,0,0,0"
                    Click="BtnBrowseOutput_Click"
                    Content="찾기..." />
            </Grid>
        </StackPanel>

        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock
                    Margin="0,0,0,5"
                    FontWeight="Bold"
                    Text="포함할 확장자:" />
                <TextBox
                    x:Name="TxtExtensions"
                    Height="25"
                    Padding="5,0"
                    VerticalContentAlignment="Center"
                    Text=".cs, .xaml, .cpp, .h" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock
                    Margin="0,0,0,5"
                    FontWeight="Bold"
                    Text="제외할 폴더:" />
                <TextBox
                    x:Name="TxtExcludedFolders"
                    Height="25"
                    Padding="5,0"
                    VerticalContentAlignment="Center"
                    Text="bin, obj, .git, .vs" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="4" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <CheckBox
                    x:Name="ChkSelectiveMerge"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Content="선택 파일만 병합"
                    FontWeight="Bold" />

                <!--  새롭게 분리된 파일 선택 버튼  -->
                <Button
                    x:Name="BtnSelectFiles"
                    Width="90"
                    Height="30"
                    Margin="0,0,15,0"
                    Background="#E1E1E1"
                    Click="BtnSelectFiles_Click"
                    Content="파일 선택..." />

                <Button
                    x:Name="BtnMerge"
                    Width="260"
                    Height="40"
                    Background="#0078D7"
                    Click="BtnMerge_Click"
                    Content="소스 코드 병합 시작"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="White" />
            </StackPanel>

            <Button
                x:Name="BtnCopyToClipboard"
                Grid.Column="2"
                Height="40"
                Background="#28A745"
                Click="BtnCopyToClipboard_Click"
                Content="📋 클립보드 복사"
                FontSize="14"
                FontWeight="Bold"
                Foreground="White"
                IsEnabled="False" />
        </Grid>

        <TextBlock
            Grid.Row="5"
            Margin="0,0,0,5"
            FontWeight="Bold"
            Text="진행 상황 / 로그:" />
        <TextBox
            x:Name="TxtLog"
            Grid.Row="6"
            Padding="10"
            Background="#1E1E1E"
            FontFamily="Consolas"
            Foreground="#D4D4D4"
            IsReadOnly="True"
            TextWrapping="Wrap"
            VerticalScrollBarVisibility="Auto" />
    </Grid>
</Window>