<Window
    x:Class="CodeMergerUI.CodeApprovalWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AI 에이전트 코드 변경 제안 승인"
    Width="750"
    Height="600"
    WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- 헤더 및 파일 정보 -->
            <RowDefinition Height="Auto" /> <!-- 수정 의도/설명 -->
            <RowDefinition Height="*" />    <!-- 코드 본문 뷰어 -->
            <RowDefinition Height="Auto" /> <!-- 반려 사유 입력란 -->
            <RowDefinition Height="Auto" /> <!-- 조작 버튼 -->
        </Grid.RowDefinitions>

        <!-- 1. 헤더 및 파일 정보 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock
                FontSize="16"
                FontWeight="Bold"
                Foreground="#0078D7"
                Text="📋 AI 에이전트가 코드를 수정하려고 제안했습니다." />
            <Grid Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    FontWeight="Bold"
                    Text="대상 파일:" />
                <TextBlock
                    x:Name="TxtFilePath"
                    Grid.Column="1"
                    Foreground="#555555"
                    Text="C:/path/to/file.cs"
                    TextWrapping="Wrap" />
            </Grid>
        </StackPanel>

        <!-- 2. 수정 설명 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock
                FontWeight="Bold"
                Text="수정 목적 및 설명:" />
            <Border
                Margin="0,5,0,0"
                Padding="8"
                Background="#F9F9F9"
                BorderBrush="#E2E2E2"
                BorderThickness="1"
                CornerRadius="4">
                <TextBlock
                    x:Name="TxtDescription"
                    Foreground="#333333"
                    Text="이 코드의 변경 사항에 대한 설명이 여기에 표시됩니다."
                    TextWrapping="Wrap" />
            </Border>
        </StackPanel>

        <!-- 3. 제안된 코드 뷰어 -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock
                Grid.Row="0"
                Margin="0,0,0,5"
                FontWeight="Bold"
                Text="제안된 코드 본문 (Proposed Code):" />
            <Border
                Grid.Row="1"
                Background="#1E1E1E"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="4">
                <TextBox
                    x:Name="TxtProposedCode"
                    Padding="10"
                    AcceptsReturn="True"
                    Background="Transparent"
                    BorderThickness="0"
                    FontFamily="Consolas"
                    FontSize="12"
                    Foreground="#D4D4D4"
                    IsReadOnly="True"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    TextWrapping="NoWrap" />
            </Border>
        </Grid>

        <!-- 4. 반려 사유 입력란 -->
        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock
                FontWeight="Bold"
                Text="반려 피드백 (반려 시 에이전트에게 전송할 메시지):" />
            <TextBox
                x:Name="TxtFeedback"
                Height="55"
                Margin="0,5,0,0"
                Padding="5"
                AcceptsReturn="True"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                TextWrapping="Wrap"
                VerticalScrollBarVisibility="Auto" />
        </StackPanel>

        <!-- 5. 조작 버튼 -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="11"
                Foreground="#888888"
                Text="* 승인하면 파일에 반영되고, 반려하면 피드백이 AI에게 전달됩니다." />

            <Button
                x:Name="BtnReject"
                Grid.Column="1"
                Width="120"
                Height="36"
                Background="#DC3545"
                Click="BtnReject_Click"
                Content="❌ 반려 (Reject)"
                FontWeight="Bold"
                Foreground="White" />

            <Button
                x:Name="BtnApprove"
                Grid.Column="3"
                Width="150"
                Height="36"
                Background="#28A745"
                Click="BtnApprove_Click"
                Content="✅ 승인 (Approve)"
                FontWeight="Bold"
                Foreground="White" />
        </Grid>
    </Grid>
</Window>
